# Dependencies
node_modules/

# Build output
dist/
**/dist/
*.tsbuildinfo

# Vite cache
.vite/
**/.vite/

# Environment secrets - per-install
.env
server/.env
.dev.vars

# Google Calendar BYO credentials + OAuth tokens. Per-install, NEVER commit.
**/00_System/.google-config.json
**/00_System/.google-tokens.json
sample-vault/00_System/.google-config.json
sample-vault/00_System/.google-tokens.json

# Logs
*.log
/tmp/solo-os-*.log

# OS junk
.DS_Store
Thumbs.db

# Editor settings (per-machine)
.vscode/
.idea/

# Local-only isolated test runner + its scratch vault. Never ship. Testing
# happens against ~/.solo-os-testvault (outside this repo) so the tracked
# sample-vault can never be dirtied by a test run.
test-run.sh
test-vault/

# Lock-file hygiene: keep them. They pin dep versions for every install.
# !package-lock.json

# Each install has its own VAULT_ROOT. The bundled sample-vault is committed
# so a fresh clone boots into example data. Users with a real vault should
# point VAULT_ROOT elsewhere - don't put their data inside this repo.

# sample-vault runtime artifacts (created when the dashboard runs against it - never ship)
sample-vault/00_System/dashboard-chats/
sample-vault/**/.transcript-baseline
sample-vault/**/.transcript-baseline*
sample-vault/00_System/reputation-analysis.json
